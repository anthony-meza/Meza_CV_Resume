% Header commands (CV.tex-compatible)
\makeatletter
\def\@headerName{}
\def\@headerContact{}
\newcommand{\headerName}[1]{\def\@headerName{#1}}
\newcommand{\contactSep}{\unskip\hspace{0.25em}\textbullet\hspace{0.25em}\ignorespaces}
\newcommand{\headerTitle}[1]{%
  \begin{center}
    \renewcommand{\arraystretch}{1.08}%
    \begin{tabular}{c}
      {\HeaderFont \huge \textsc{\@headerName}} \\
      \if\relax\detokenize{#1}\relax
      \else
        {\HeaderFont \large \textsc{#1}} \\
      \fi
      \@headerContact
    \end{tabular}
  \end{center}
}
\newcommand{\headerContact}[1]{%
  \def\@headerContact{%
    \normalsize
    {\HeaderFont #1}
  }
}
\makeatother

